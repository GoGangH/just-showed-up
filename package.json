{
  "name": "just-showed-up",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "dev:clean": "rm -rf .next && next dev -H 127.0.0.1",
    "build": "next build",
    "build:verify": "sh -c 'tmp=$(mktemp); cp next-env.d.ts \"$tmp\"; NEXT_DIST_DIR=.next-build next build; status=$?; cp \"$tmp\" next-env.d.ts; rm \"$tmp\"; exit $status'",
    "start": "next start -H 127.0.0.1",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
